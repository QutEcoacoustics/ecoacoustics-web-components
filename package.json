{
  "name": "web-components",
  "version": "0.1.0",
  "description": "A collection of simple components part of the baw web components library",
  "main": "build/src/oe-element.js",
  "module": "build/src/oe-element.js",
  "types": "build/src/oe-element.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc && rollup --config rollup.config.js",
    "build:watch": "tsc --watch",
    "clean": "rimraf oe-element.{d.ts,d.ts.map,js,js.map} test/oe-element.{d.ts,d.ts.map,js,js.map} test/oe-element_test.{d.ts,d.ts.map,js,js.map}",
    "lint": "npm run lint:lit-analyzer && npm run lint:eslint && npm run lint:html",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "lint:lit-analyzer": "lit-analyzer",
    "lint:html": "html-validate --ext html dev src docs-src",
    "format": "prettier \"**/*.{cjs,html,js,json,md,ts}\" --ignore-path ./.eslintignore --write",
    "docs": "npm run docs:clean && npm run build && npm run analyze && npm run docs:build && npm run docs:assets && npm run docs:gen",
    "docs:watch": "npm run docs:clean && npm run build && npm run analyze && npm run docs:build && npm run docs:assets && npm run docs:gen:watch",
    "docs:clean": "rimraf docs",
    "docs:gen": "eleventy --config=.eleventy.cjs",
    "docs:gen:watch": "eleventy --config=.eleventy.cjs --watch",
    "docs:build": "rollup --config rollup.config.js --dir docs",
    "docs:assets": "cp node_modules/prismjs/themes/prism-okaidia.css docs/",
    "docs:serve": "wds --root-dir=docs --node-resolve --watch",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\" --outdir docs-src/_data",
    "analyze:watch": "cem analyze --litelement --globs \"src/**/*.ts\" --watch --outdir docs-src/_data",
    "serve": "wds --watch",
    "serve:dev": "wds --watch --config web-dev-server-dev.config.js",
    "serve:prod": "npm run set_production_mode && npm run serve",
    "test": "npm run test:dev && npm run test:prod",
    "test:dev": "wtr",
    "test:watch": "wtr --watch",
    "test:prod": "MODE=prod wtr",
    "test:prod:watch": "MODE=prod wtr --watch",
    "checksize": "rollup -c ; cat build/dist/oe-*.js | gzip -9 | wc -c ; rimraf build/dist",
    "prepare": "husky install",
    "set_production_mode": "set MODE=prod"
  },
  "keywords": [
    "web-components",
    "lit-element",
    "typescript",
    "lit"
  ],
  "author": "Charles Alleman, Anthony Truskinger, Benjamin Rowe",
  "license": "MIT",
  "dependencies": {
    "@open-wc/lit-helpers": "^0.4.0-next.1",
    "lit": "^2.0.0",
    "rxjs": "^7.4.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^0.12.1",
    "@11ty/eleventy-plugin-syntaxhighlight": "^3.0.1",
    "@commitlint/cli": "^15.0.0",
    "@commitlint/config-conventional": "^15.0.0",
    "@custom-elements-manifest/analyzer": "^0.5.3",
    "@esm-bundle/chai": "^4.1.5",
    "@open-wc/testing": "^3.0.0-next.1",
    "@open-wc/testing-karma": "^4.0.9",
    "@rollup/plugin-multi-entry": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.0.6",
    "@rollup/plugin-replace": "^3.0.0",
    "@types/mocha": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^4.3.0",
    "@typescript-eslint/parser": "^4.30.0",
    "@web/dev-server": "^0.1.22",
    "@web/dev-server-legacy": "^0.1.4",
    "@web/dev-server-rollup": "^0.3.9",
    "@web/rollup-plugin-copy": "^0.3.0",
    "@web/rollup-plugin-html": "^1.10.1",
    "@web/test-runner": "^0.13.16",
    "@web/test-runner-mocha": "^0.7.4",
    "@web/test-runner-playwright": "^0.8.4",
    "@webcomponents/webcomponentsjs": "^2.6.0",
    "deepmerge": "^4.2.2",
    "eslint": "^7.32.0",
    "html-validate": "^6.1.3",
    "husky": "^7.0.0",
    "lit-analyzer": "^1.1.10",
    "mocha": "^9.1.1",
    "prettier": "^2.3.2",
    "rimraf": "^3.0.2",
    "rollup": "^2.60.2",
    "rollup-plugin-minify-html-literals": "^1.2.6",
    "rollup-plugin-multi-input": "^1.3.1",
    "rollup-plugin-summary": "^1.3.0",
    "rollup-plugin-terser": "^7.0.2",
    "sinon": "^12.0.1",
    "typescript": "^4.3.5"
  },
  "customElements": "docs-src/_data/custom-elements.json"
}
